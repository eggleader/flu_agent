# BioAgent 配置文件示例
# 复制此文件为 config.yaml 并修改相应配置

# ========== LLM 配置 ==========
llm:
  base_url: "http://localhost:11434"
  model: "qwen3:4b"
  temperature: 0.7
  timeout: 300
  max_tokens: 4096

# ========== 路径配置 ==========
paths:
  tools_dir: "tools"
  knowledge_dir: "knowledge"
  workflow_dir: "workflow"
  data_dir: "data"
  reports_dir: "reports"
  example_dir: "example"

# ========== 生信工具路径配置 ==========
# 格式: "工具名: 路径"
# 引擎启动时会自动检测可用性，如果路径不存在会尝试在 PATH 中查找
tools:
  # 序列处理
  seqkit: "/path/to/seqkit"

  # 质控
  fastp: "/path/to/fastp"
  fastqc: "/path/to/fastqc"
  multiqc: "/path/to/multiqc"
  cutadapt: "/path/to/cutadapt"

  # 组装
  spades: "/path/to/spades.py"
  megahit: "/path/to/megahit"

  # 比对与排序
  bwa: "/path/to/bwa"
  minimap2: "/path/to/minimap2"
  samtools: "/path/to/samtools"
  blastn: "/path/to/blastn"
  diamond: "/path/to/diamond"

  # 分类
  kraken2: "/path/to/kraken2"

  # 多序列比对
  mafft: "/path/to/mafft"
  trimal: "/path/to/trimal"

  # 蛋白结构比对
  hhblits: "/path/to/hhblits"
  hhsearch: "/path/to/hhsearch"
  hhfilter: "/path/to/hhfilter"

  # 进化分析
  iqtree2: "/path/to/iqtree2"
  codeml: "/path/to/codeml"
  baseml: "/path/to/baseml"

  # 其他
  swarm: "/path/to/swarm"
  circos: "/path/to/circos"

# ========== Agent 配置 ==========
agent:
  # 最大工具调用轮次
  max_tool_rounds: 10
  # 是否启用 Planner-Executor 模式（复杂任务自动切换）
  enable_planner: true
  # 简单任务阈值（工具调用数 >= 此值时启用 Planner）
  planner_threshold: 2
  # 默认线程数
  default_threads: 4
  # 命令执行超时（秒）
  command_timeout: 600

# ========== Web UI 配置 ==========
web:
  enable: false
  port: 7860
  share: false
  debug: false

# ========== 数据库配置 ==========
database:
  type: "sqlite"
  path: "data/sessions/bioagent.db"

# ========== 日志配置 ==========
logging:
  level: "INFO"
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  file: "bioagent.log"
